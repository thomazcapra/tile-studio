{
  "name": "tile-studio-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that exposes Tile Studio's pixel-art and tilemap engine as tools for Claude and other AI assistants.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tile-studio-mcp": "./bin/tile-studio-mcp.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
